# Agent Rook — Environment Variables
# Copy this to .env and fill in your values

# Required
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET_KEY=change-me-to-another-random-string
ANTHROPIC_API_KEY=sk-ant-your-key-here
DATABASE_URL=sqlite:///agentrook.db

# Optional — Redis (enables rate limiting, memory caching, daily limits)
# REDIS_URL=redis://localhost:6379/0

# Optional — Stripe (enables credit purchases)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional — SendGrid (enables password reset emails)
# SENDGRID_API_KEY=SG...
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Optional — Sentry (error tracking)
# SENTRY_DSN=https://...@sentry.io/...

# Optional — Model overrides (defaults from agent.yaml)
# AI_MODEL_FAST=claude-haiku-4-20250514
# AI_MODEL_SMART=claude-sonnet-4-20250514

# Admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Production
# FLASK_ENV=production
